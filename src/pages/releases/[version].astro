---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const releases = await getCollection('releases');
  return releases.map((release) => ({
    params: { version: release.slug },
    props: { release },
  }));
}

const { release } = Astro.props;
const { Content } = await release.render();
const { version, release_date, summary, features, fixed_issues, known_issues } = release.data;

const dateStr = release_date.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});

const byCategory = features.reduce<Record<string, typeof features>>((acc, f) => {
  (acc[f.category] ??= []).push(f);
  return acc;
}, {});
---
