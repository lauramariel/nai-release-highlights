---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import VersionEntry from '../components/VersionEntry.astro';
import Search from '../components/Search.astro';

const releases = await getCollection('releases');
const sorted = [...releases].sort(
  (a, b) => b.data.release_date.getTime() - a.data.release_date.getTime()
);
---

<Base>
  <Search />
  <div class="timeline">
    {sorted.map((release, i) => (
      <VersionEntry release={release} isLatest={i === 0} />
    ))}
  </div>
</Base>

<style>
  .timeline { padding-top: 8px; }
</style>
